# Environment variables for the project

LANGCHAIN_TRACING_V2=true # Set to true to enable LangSmith tracing
LANGCHAIN_API_KEY=""

# ── LLM providers ──────────────────────────────────────────────────────────────
# Detective / Judge / ChiefJustice agent orchestration:
ANTHROPIC_API_KEY=""

# VisionInspector diagram analysis — provider priority: Google → Anthropic → OpenAI
# Set GOOGLE_API_KEY to use Gemini 2.5 Flash (recommended for vision).
# Falls back to ANTHROPIC_API_KEY (Claude) or OPENAI_API_KEY (GPT-4o) if unset.
GOOGLE_API_KEY=""
# OPENAI_API_KEY=""

# ── Feature flags ──────────────────────────────────────────────────────────────
VISION_ENABLED=false # Set to true to enable diagram analysis

# LLM model for the Detectives
DETECTIVE_MODEL=

# LLM model for the Judicial Layer
JUDICIAL_MODEL=

# LLM model for the Chief Justice
CHIEF_JUDGE_MODEL=

# Maximum iterations per detective agent call
DETECTIVE_MAX_ITERATIONS=