# Environment variables for the project

LANGCHAIN_TRACING_V2=true # Set to true to enable LangSmith tracing
LANGCHAIN_API_KEY=""

# ── LLM provider for VisionInspector diagram analysis ─────────────────────────
# Set ONE of the following.  Anthropic is preferred (already a dependency).
# Google is the alternative and used for diagram analysis.

ANTHROPIC_API_KEY=""

GOOGLE_API_KEY=""

# ── Feature flags ──────────────────────────────────────────────────────────────
VISION_ENABLED=false # Set to true to enable diagram analysis

# LLM model for the Detectives
DETECTIVE_MODEL=

# LLM model for the Judicial Layer
JUDICIAL_MODEL=

# LLM model for the Chief Justice
CHIEF_JUDGE_MODEL=

# Maximum iterations per detective agent call
DETECTIVE_MAX_ITERATIONS=